{
  "rules": {
    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "games": {
      "$gameId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "chat": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    }
  }
}
