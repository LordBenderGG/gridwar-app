rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USUARIOS ─────────────────────────────────────────────────────────────
    // Lectura pública para cualquier auth (home, clasificación, salón)
    // Escritura: el dueño puede escribir su propio doc.
    // TAMBIÉN cualquier auth puede actualizar campos de otros usuarios:
    // esto es necesario para que el sistema cambie status/points/rank del rival
    // al terminar una partida o procesar un reto (finishMatch, penalizeNoAccept,
    // sendChallenge, expireChallenge, etc.)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Historial de partidas — solo el dueño puede leer/escribir
    // (el sistema escribe con las credenciales del usuario activo en la sesión)
    match /users/{userId}/history/{gameId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }

    // ── RETOS ────────────────────────────────────────────────────────────────
    // La query subscribeToIncomingChallenges usa where('to','==',uid) +
    // where('status','==','pending'). Firestore evalúa las reglas antes de
    // aplicar el filtro, por lo que la regla de lectura debe ser permisiva
    // para cualquier usuario autenticado (no solo from/to).
    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── PARTIDAS ─────────────────────────────────────────────────────────────
    // Ambos jugadores y el sistema necesitan leer y actualizar el doc de partida.
    match /games/{gameId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── TORNEOS ──────────────────────────────────────────────────────────────
    match /tournaments/{tournamentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── CATCH-ALL: bloquear todo lo demás ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
