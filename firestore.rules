rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Campos que un usuario ajeno (autenticado) puede actualizar en nombre del juego:
    // resultados de partida, estado en-línea, racha y gemas ganadas como recompensa.
    // NO incluye campos de perfil (username, avatar, photoURL) ni inventario de tienda.
    function onlyGameFields(request, resource) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let allowed = [
        'points', 'gems', 'wins', 'losses', 'gamesPlayed', 'rank',
        'status', 'currentWinStreak', 'maxWinStreak',
        'challengeBlockedUntil', 'activeChallengeId',
        'xp', 'level'
      ].toSet();
      return changed.hasOnly(allowed);
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;

      // El propio usuario puede actualizar cualquier campo de su perfil.
      // Un usuario ajeno (autenticado) solo puede actualizar los campos
      // estrictamente relacionados con resultados de partida — no puede
      // tocar nombre, avatar, fotos, gemas ni inventario.
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        onlyGameFields(request, resource)
      );
      allow delete: if false;
    }

    match /users/{userId}/history/{gameId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }

    match /users/{userId}/dailyPurchases/{purchaseId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/achievements/{achievementId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/dailyMissions/{date} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    match /games/{gameId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    match /tournaments/{tournamentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /economy/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /seasons/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /seasons/{seasonId}/leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /meta/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Dedupe de royalties del creador (eventos por transacción)
    match /meta/royaltyEvents/events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
