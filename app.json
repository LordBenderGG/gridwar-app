{
  "expo": {
    "name": "GRIDWAR",
    "slug": "gridwar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1624"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gridwar.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./logo.png",
        "backgroundColor": "#0F1624"
      },
      "package": "com.gridwar.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_MULTICAST_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "./node_modules/expo-router/app.plugin.js",
      "./node_modules/expo-font/app.plugin.js",
      [
        "./node_modules/expo-notifications/app.plugin.js",
        {
          "icon": "./logo.png",
          "color": "#60A5FA"
        }
      ],
      [
        "./node_modules/react-native-google-mobile-ads/app.plugin.js",
        {
          "androidAppId": "ca-app-pub-9019813013540172~1893379866",
          "iosAppId": "ca-app-pub-9019813013540172~1893379866"
        }
      ]
    ],
    "react-native-google-mobile-ads": {
      "android_app_id": "ca-app-pub-9019813013540172~1893379866"
    },
    "scheme": "gridwar",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "fc9a81f1-2663-4874-8d18-6246d2c44354"
      }
    },
    "owner": "lord.bender"
  }
}